{% extends 'base.html.twig' %}

{% block title %}Admin - Produkty{% endblock %}

{% block body %}
<h1>Zarządzanie produktami</h1>
<a href="/admin" class="btn btn-secondary mb-3">Powrót do panelu</a>
<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nazwa</th>
            <th>Opis</th>
            <th>Cena</th>
            <th>Kategoria</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        {% for product in products %}
        <tr>
            <td>{{ product.id }}</td>
            <td>{{ product.name }}</td>
            <td>{{ product.description }}</td>
            <td>{{ product.price }} zł</td>
            <td>{{ product.category ? product.category.name : '-' }}</td>
            <td>
                <a href="/admin/product/{{ product.id }}/edit" class="btn btn-sm btn-warning">Edytuj</a>
                <form action="/admin/product/{{ product.id }}/delete" method="POST" style="display:inline">
                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Usunąć?')">Usuń</button>
                </form>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
