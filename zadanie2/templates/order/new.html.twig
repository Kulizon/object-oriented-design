{% extends 'base.html.twig' %}

{% block title %}Nowe zamówienie{% endblock %}

{% block body %}
<h1>Nowe zamówienie</h1>
<form method="POST">
    <div class="mb-3">
        <label class="form-label">Klient</label>
        <input type="text" name="customer_name" class="form-control" required>
    </div>
    <div class="mb-3">
        <label class="form-label">Produkty</label>
        <select name="product_ids[]" class="form-select" multiple size="5">
            {% for product in products %}
            <option value="{{ product.id }}">{{ product.name }} ({{ product.price }} zł)</option>
            {% endfor %}
        </select>
        <small class="text-muted">Przytrzymaj Ctrl aby wybrać wiele</small>
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a href="/order" class="btn btn-secondary">Anuluj</a>
</form>
{% endblock %}
