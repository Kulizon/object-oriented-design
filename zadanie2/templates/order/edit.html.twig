{% extends 'base.html.twig' %}

{% block title %}Edytuj zamówienie{% endblock %}

{% block body %}
<h1>Edytuj zamówienie #{{ order.id }}</h1>
<form method="POST">
    <div class="mb-3">
        <label class="form-label">Klient</label>
        <input type="text" name="customer_name" class="form-control" value="{{ order.customerName }}" required>
    </div>
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            <option value="new" {{ order.status == 'new' ? 'selected' : '' }}>new</option>
            <option value="processing" {{ order.status == 'processing' ? 'selected' : '' }}>processing</option>
            <option value="completed" {{ order.status == 'completed' ? 'selected' : '' }}>completed</option>
            <option value="cancelled" {{ order.status == 'cancelled' ? 'selected' : '' }}>cancelled</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Produkty</label>
        <select name="product_ids[]" class="form-select" multiple size="5">
            {% set orderProductIds = [] %}
            {% for p in order.products %}
                {% set orderProductIds = orderProductIds|merge([p.id]) %}
            {% endfor %}
            {% for product in products %}
            <option value="{{ product.id }}" {{ product.id in orderProductIds ? 'selected' : '' }}>{{ product.name }} ({{ product.price }} zł)</option>
            {% endfor %}
        </select>
        <small class="text-muted">Przytrzymaj Ctrl aby wybrać wiele</small>
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a href="/order" class="btn btn-secondary">Anuluj</a>
</form>
{% endblock %}
