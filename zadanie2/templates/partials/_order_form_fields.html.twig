    <div class="mb-3">
        <label class="form-label" for="customer_name">Klient</label>
        <input type="text" name="customer_name" id="customer_name" class="form-control" value="{{ order.customerName | default('') }}" required>
    </div>
    {% if order is defined and order.id %}
    <div class="mb-3">
        <label class="form-label" for="status">Status</label>
        <select name="status" id="status" class="form-select">
            <option value="new" {{ order.status == 'new' ? 'selected' : '' }}>new</option>
            <option value="processing" {{ order.status == 'processing' ? 'selected' : '' }}>processing</option>
            <option value="completed" {{ order.status == 'completed' ? 'selected' : '' }}>completed</option>
            <option value="cancelled" {{ order.status == 'cancelled' ? 'selected' : '' }}>cancelled</option>
        </select>
    </div>
    {% endif %}
    <div class="mb-3">
        <label class="form-label" for="product_ids">Produkty</label>
        <select name="product_ids[]" id="product_ids" class="form-select" multiple size="5">
            {% set orderProductIds = [] %}
            {% if order is defined %}
                {% for p in order.products %}
                    {% set orderProductIds = orderProductIds|merge([p.id]) %}
                {% endfor %}
            {% endif %}
            {% for product in products %}
            <option value="{{ product.id }}" {{ product.id in orderProductIds ? 'selected' : '' }}>{{ product.name }} ({{ product.price }} zł)</option>
            {% endfor %}
        </select>
        <small class="text-muted">Przytrzymaj Ctrl aby wybrać wiele</small>
    </div>
